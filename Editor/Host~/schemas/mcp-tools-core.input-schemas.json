{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity MCP Core Tool Input Schemas",
  "version": "0.1.0",
  "$defs": {
    "scenePath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.unity$",
      "description": "Scene path under Assets/"
    },
    "guid": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{32}$",
      "description": "Unity GUID"
    },
    "assetPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Asset path under Assets/"
    },
    "folderPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Folder path under Assets/"
    },
    "prefabPath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.prefab$",
      "description": "Prefab path under Assets/"
    },
    "assetRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "guid": {
              "$ref": "#/$defs/guid"
            }
          },
          "required": [
            "guid"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "$ref": "#/$defs/assetPath"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        }
      ]
    },
    "gameObjectRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "globalObjectId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "globalObjectId"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "scenePath": {
              "$ref": "#/$defs/scenePath"
            },
            "hierarchyPath": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "scenePath",
            "hierarchyPath"
          ],
          "additionalProperties": false
        }
      ]
    },
    "vec3": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false
    },
    "transformInput": {
      "type": "object",
      "properties": {
        "position": {
          "$ref": "#/$defs/vec3"
        },
        "rotationEuler": {
          "$ref": "#/$defs/vec3"
        },
        "scale": {
          "$ref": "#/$defs/vec3"
        },
        "local": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "mutateFlags": {
      "type": "object",
      "allOf": [
        {
          "if": {
            "required": [
              "dryRun"
            ]
          },
          "then": {
            "required": [
              "apply"
            ]
          }
        },
        {
          "if": {
            "required": [
              "apply"
            ]
          },
          "then": {
            "required": [
              "dryRun"
            ]
          }
        },
        {
          "if": {
            "required": [
              "dryRun",
              "apply"
            ]
          },
          "then": {
            "oneOf": [
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": true
                  },
                  "apply": {
                    "const": false
                  }
                }
              },
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": false
                  },
                  "apply": {
                    "const": true
                  }
                }
              }
            ]
          }
        }
      ]
    }
  },
  "tools": [
    {
      "name": "unity.ping",
      "description": "Verify bridge connectivity and editor heartbeat.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "name": "unity.project_info",
      "description": "Return project/runtime/editor basics.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "includePlatformMatrix": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "unity.playmode_status",
      "description": "Query play mode runtime state.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "name": "unity.playmode_start",
      "description": "Enter play mode and optionally wait until state transition completes.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "waitForEntered": {
            "type": "boolean",
            "default": true
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 1000,
            "maximum": 120000,
            "default": 15000
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "unity.playmode_stop",
      "description": "Exit play mode and optionally wait until complete.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "waitForExited": {
            "type": "boolean",
            "default": true
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 1000,
            "maximum": 120000,
            "default": 15000
          }
        },
        "additionalProperties": false
      }
    }
  ]
}
