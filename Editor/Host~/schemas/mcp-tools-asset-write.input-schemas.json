{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity MCP Asset Write Tool Input Schemas",
  "version": "0.1.0",
  "$defs": {
    "scenePath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.unity$",
      "description": "Scene path under Assets/"
    },
    "guid": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{32}$",
      "description": "Unity GUID"
    },
    "assetPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Asset path under Assets/"
    },
    "folderPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Folder path under Assets/"
    },
    "prefabPath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.prefab$",
      "description": "Prefab path under Assets/"
    },
    "assetRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "guid": {
              "$ref": "#/$defs/guid"
            }
          },
          "required": [
            "guid"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "$ref": "#/$defs/assetPath"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        }
      ]
    },
    "gameObjectRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "globalObjectId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "globalObjectId"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "scenePath": {
              "$ref": "#/$defs/scenePath"
            },
            "hierarchyPath": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "scenePath",
            "hierarchyPath"
          ],
          "additionalProperties": false
        }
      ]
    },
    "vec3": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false
    },
    "transformInput": {
      "type": "object",
      "properties": {
        "position": {
          "$ref": "#/$defs/vec3"
        },
        "rotationEuler": {
          "$ref": "#/$defs/vec3"
        },
        "scale": {
          "$ref": "#/$defs/vec3"
        },
        "local": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "mutateFlags": {
      "type": "object",
      "allOf": [
        {
          "if": {
            "required": [
              "dryRun"
            ]
          },
          "then": {
            "required": [
              "apply"
            ]
          }
        },
        {
          "if": {
            "required": [
              "apply"
            ]
          },
          "then": {
            "required": [
              "dryRun"
            ]
          }
        },
        {
          "if": {
            "required": [
              "dryRun",
              "apply"
            ]
          },
          "then": {
            "oneOf": [
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": true
                  },
                  "apply": {
                    "const": false
                  }
                }
              },
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": false
                  },
                  "apply": {
                    "const": true
                  }
                }
              }
            ]
          }
        }
      ]
    }
  },
  "tools": [
    {
      "name": "unity.asset_move",
      "description": "Move assets into a destination folder.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "targets": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/assetRef"
            },
            "minItems": 1
          },
          "destinationFolder": {
            "$ref": "#/$defs/folderPath"
          },
          "conflictPolicy": {
            "type": "string",
            "enum": [
              "fail",
              "overwrite",
              "rename"
            ],
            "default": "fail"
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "targets",
          "destinationFolder"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity.asset_rename",
      "description": "Rename an asset.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "target": {
            "$ref": "#/$defs/assetRef"
          },
          "newName": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^\\/]+$"
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "target",
          "newName"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity.asset_delete_to_trash",
      "description": "Delete assets to OS trash/recycle bin.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "targets": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/assetRef"
            },
            "minItems": 1
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "targets"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity.asset_reimport",
      "description": "Reimport one or many assets.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "targets": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/assetRef"
            },
            "minItems": 1
          },
          "recursive": {
            "type": "boolean",
            "default": false
          },
          "forceUpdate": {
            "type": "boolean",
            "default": false
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "targets"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity.asset_set_labels",
      "description": "Set/add/remove labels for an asset.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "target": {
            "$ref": "#/$defs/assetRef"
          },
          "mode": {
            "type": "string",
            "enum": [
              "set",
              "add",
              "remove"
            ]
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "target",
          "mode",
          "labels"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    }
  ]
}
