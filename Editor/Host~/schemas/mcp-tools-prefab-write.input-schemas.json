{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity MCP Prefab Write Tool Input Schemas",
  "version": "0.1.0",
  "$defs": {
    "scenePath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.unity$",
      "description": "Scene path under Assets/"
    },
    "guid": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{32}$",
      "description": "Unity GUID"
    },
    "assetPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Asset path under Assets/"
    },
    "folderPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Folder path under Assets/"
    },
    "prefabPath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.prefab$",
      "description": "Prefab path under Assets/"
    },
    "assetRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "guid": {
              "$ref": "#/$defs/guid"
            }
          },
          "required": [
            "guid"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "$ref": "#/$defs/assetPath"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        }
      ]
    },
    "gameObjectRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "globalObjectId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "globalObjectId"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "scenePath": {
              "$ref": "#/$defs/scenePath"
            },
            "hierarchyPath": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "scenePath",
            "hierarchyPath"
          ],
          "additionalProperties": false
        }
      ]
    },
    "vec3": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false
    },
    "transformInput": {
      "type": "object",
      "properties": {
        "position": {
          "$ref": "#/$defs/vec3"
        },
        "rotationEuler": {
          "$ref": "#/$defs/vec3"
        },
        "scale": {
          "$ref": "#/$defs/vec3"
        },
        "local": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "mutateFlags": {
      "type": "object",
      "allOf": [
        {
          "if": {
            "required": [
              "dryRun"
            ]
          },
          "then": {
            "required": [
              "apply"
            ]
          }
        },
        {
          "if": {
            "required": [
              "apply"
            ]
          },
          "then": {
            "required": [
              "dryRun"
            ]
          }
        },
        {
          "if": {
            "required": [
              "dryRun",
              "apply"
            ]
          },
          "then": {
            "oneOf": [
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": true
                  },
                  "apply": {
                    "const": false
                  }
                }
              },
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": false
                  },
                  "apply": {
                    "const": true
                  }
                }
              }
            ]
          }
        }
      ]
    }
  },
  "tools": [
    {
      "name": "unity.prefab_create",
      "description": "Save a scene object as a prefab.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source": {
            "$ref": "#/$defs/gameObjectRef"
          },
          "outputPath": {
            "$ref": "#/$defs/prefabPath"
          },
          "connectToInstance": {
            "type": "boolean",
            "default": true
          },
          "overwrite": {
            "type": "boolean",
            "default": false
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "source",
          "outputPath"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity.prefab_instantiate",
      "description": "Instantiate a prefab into a scene.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prefab": {
            "$ref": "#/$defs/assetRef"
          },
          "scenePath": {
            "$ref": "#/$defs/scenePath"
          },
          "parent": {
            "$ref": "#/$defs/gameObjectRef"
          },
          "transform": {
            "$ref": "#/$defs/transformInput"
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "prefab"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity.prefab_apply_overrides",
      "description": "Apply prefab overrides from instances to source prefabs.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "instances": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/gameObjectRef"
            },
            "minItems": 1
          },
          "includePropertyOverrides": {
            "type": "boolean",
            "default": true
          },
          "includeAddedComponents": {
            "type": "boolean",
            "default": true
          },
          "includeRemovedComponents": {
            "type": "boolean",
            "default": true
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "instances"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity.prefab_revert_overrides",
      "description": "Revert prefab overrides on instances.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "instances": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/gameObjectRef"
            },
            "minItems": 1
          },
          "includePropertyOverrides": {
            "type": "boolean",
            "default": true
          },
          "includeAddedComponents": {
            "type": "boolean",
            "default": true
          },
          "includeRemovedComponents": {
            "type": "boolean",
            "default": true
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "instances"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity.prefab_unpack",
      "description": "Unpack prefab instances.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "instances": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/gameObjectRef"
            },
            "minItems": 1
          },
          "mode": {
            "type": "string",
            "enum": [
              "OutermostRoot",
              "Completely"
            ],
            "default": "OutermostRoot"
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "instances"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity.prefab_create_variant",
      "description": "Create a prefab variant from base prefab (optionally using instance overrides).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "basePrefab": {
            "$ref": "#/$defs/assetRef"
          },
          "outputPath": {
            "$ref": "#/$defs/prefabPath"
          },
          "sourceInstance": {
            "$ref": "#/$defs/gameObjectRef"
          },
          "overwrite": {
            "type": "boolean",
            "default": false
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "basePrefab",
          "outputPath"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    }
  ]
}
