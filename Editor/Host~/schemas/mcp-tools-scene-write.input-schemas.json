{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity MCP Scene Write Tool Input Schemas",
  "version": "0.1.0",
  "$defs": {
    "scenePath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.unity$",
      "description": "Scene path under Assets/"
    },
    "guid": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{32}$",
      "description": "Unity GUID"
    },
    "assetPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Asset path under Assets/"
    },
    "folderPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Folder path under Assets/"
    },
    "prefabPath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.prefab$",
      "description": "Prefab path under Assets/"
    },
    "assetRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "guid": {
              "$ref": "#/$defs/guid"
            }
          },
          "required": [
            "guid"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "$ref": "#/$defs/assetPath"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        }
      ]
    },
    "gameObjectRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "globalObjectId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "globalObjectId"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "scenePath": {
              "$ref": "#/$defs/scenePath"
            },
            "hierarchyPath": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "scenePath",
            "hierarchyPath"
          ],
          "additionalProperties": false
        }
      ]
    },
    "vec3": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false
    },
    "transformInput": {
      "type": "object",
      "properties": {
        "position": {
          "$ref": "#/$defs/vec3"
        },
        "rotationEuler": {
          "$ref": "#/$defs/vec3"
        },
        "scale": {
          "$ref": "#/$defs/vec3"
        },
        "local": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "mutateFlags": {
      "type": "object",
      "allOf": [
        {
          "if": {
            "required": [
              "dryRun"
            ]
          },
          "then": {
            "required": [
              "apply"
            ]
          }
        },
        {
          "if": {
            "required": [
              "apply"
            ]
          },
          "then": {
            "required": [
              "dryRun"
            ]
          }
        },
        {
          "if": {
            "required": [
              "dryRun",
              "apply"
            ]
          },
          "then": {
            "oneOf": [
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": true
                  },
                  "apply": {
                    "const": false
                  }
                }
              },
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": false
                  },
                  "apply": {
                    "const": true
                  }
                }
              }
            ]
          }
        }
      ]
    }
  },
  "tools": [
    {
      "name": "unity_go_create",
      "description": "Create a new GameObject.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "scenePath": {
            "$ref": "#/$defs/scenePath"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "parent": {
            "$ref": "#/$defs/gameObjectRef"
          },
          "transform": {
            "$ref": "#/$defs/transformInput"
          },
          "components": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "minLength": 1
                },
                "fields": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            }
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity_go_delete",
      "description": "Delete one or many GameObjects.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "targets": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/gameObjectRef"
            },
            "minItems": 1
          },
          "mode": {
            "type": "string",
            "enum": [
              "undoable",
              "immediate"
            ],
            "default": "undoable"
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "targets"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity_go_duplicate",
      "description": "Duplicate one or many GameObjects.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "targets": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/gameObjectRef"
            },
            "minItems": 1
          },
          "parent": {
            "$ref": "#/$defs/gameObjectRef"
          },
          "renamePattern": {
            "type": "string",
            "minLength": 1
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "targets"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity_go_reparent",
      "description": "Move objects under a new parent (or scene root).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "targets": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/gameObjectRef"
            },
            "minItems": 1
          },
          "newParent": {
            "$ref": "#/$defs/gameObjectRef"
          },
          "worldPositionStays": {
            "type": "boolean",
            "default": true
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "targets"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity_go_rename",
      "description": "Rename a GameObject.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "target": {
            "$ref": "#/$defs/gameObjectRef"
          },
          "newName": {
            "type": "string",
            "minLength": 1
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "target",
          "newName"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity_go_set_active",
      "description": "Set active state for GameObjects.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "targets": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/gameObjectRef"
            },
            "minItems": 1
          },
          "active": {
            "type": "boolean"
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "targets",
          "active"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity_component_add",
      "description": "Add a component to a GameObject.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "target": {
            "$ref": "#/$defs/gameObjectRef"
          },
          "componentType": {
            "type": "string",
            "minLength": 1
          },
          "fields": {
            "type": "object",
            "additionalProperties": true
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "target",
          "componentType"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity_component_remove",
      "description": "Remove one component from a GameObject by type or component id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "target": {
            "$ref": "#/$defs/gameObjectRef"
          },
          "componentType": {
            "type": "string",
            "minLength": 1
          },
          "componentId": {
            "type": "string",
            "minLength": 1
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "target"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          },
          {
            "oneOf": [
              {
                "required": [
                  "componentType"
                ]
              },
              {
                "required": [
                  "componentId"
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "name": "unity_component_set_fields",
      "description": "Set serialized fields on a component.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "target": {
            "$ref": "#/$defs/gameObjectRef"
          },
          "componentType": {
            "type": "string",
            "minLength": 1
          },
          "componentId": {
            "type": "string",
            "minLength": 1
          },
          "fields": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": true
          },
          "strict": {
            "type": "boolean",
            "default": true
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "target",
          "fields"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    }
  ]
}

