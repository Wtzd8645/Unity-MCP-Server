{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity MCP Tool Modules",
  "version": "0.1.0",
  "modules": [
    {
      "name": "project_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_project_ping",
        "unity_project_get_info"
      ]
    },
    {
      "name": "project_execute",
      "risk": "low-medium",
      "enabledByDefault": false,
      "tools": [
        "unity_project_run_tests"
      ]
    },
    {
      "name": "editor_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_editor_get_console_logs"
      ]
    },
    {
      "name": "editor_write",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_editor_clear_console"
      ]
    },
    {
      "name": "runtime_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_runtime_get_playmode_status"
      ]
    },
    {
      "name": "runtime_execute",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_runtime_start_playmode",
        "unity_runtime_stop_playmode"
      ]
    },
    {
      "name": "scene_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_scene_list",
        "unity_scene_list_loaded",
        "unity_scene_get_active",
        "unity_gameobject_find"
      ]
    },
    {
      "name": "scene_execute",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_scene_open",
        "unity_scene_set_active",
        "unity_scene_close"
      ]
    },
    {
      "name": "scene_write",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_scene_create",
        "unity_scene_save",
        "unity_scene_save_all"
      ]
    },
    {
      "name": "gameobject_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_gameobject_get"
      ]
    },
    {
      "name": "component_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_component_list",
        "unity_component_get_fields",
        "unity_component_get_fields_batch"
      ]
    },
    {
      "name": "gameobject_write",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_gameobject_create",
        "unity_gameobject_delete",
        "unity_gameobject_duplicate",
        "unity_gameobject_reparent",
        "unity_gameobject_rename",
        "unity_gameobject_set_active",
        "unity_gameobject_set_transform",
        "unity_gameobject_set_tag",
        "unity_gameobject_set_layer",
        "unity_gameobject_set_static"
      ]
    },
    {
      "name": "component_write",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_component_add",
        "unity_component_remove",
        "unity_component_set_fields"
      ]
    },
    {
      "name": "prefab_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_prefab_get",
        "unity_prefab_get_overrides"
      ]
    },
    {
      "name": "prefab_write",
      "risk": "medium-high",
      "enabledByDefault": false,
      "tools": [
        "unity_prefab_create",
        "unity_prefab_create_instance",
        "unity_prefab_apply_overrides",
        "unity_prefab_revert_overrides",
        "unity_prefab_unpack",
        "unity_prefab_create_variant"
      ]
    },
    {
      "name": "asset_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_asset_find",
        "unity_asset_get",
        "unity_asset_get_references"
      ]
    },
    {
      "name": "asset_write",
      "risk": "high",
      "enabledByDefault": false,
      "tools": [
        "unity_asset_move",
        "unity_asset_rename",
        "unity_asset_delete_to_trash",
        "unity_asset_reimport",
        "unity_asset_import",
        "unity_asset_set_labels",
        "unity_asset_copy",
        "unity_asset_create_folder",
        "unity_asset_create_text",
        "unity_asset_create_material",
        "unity_asset_create_scriptable_object"
      ]
    }
  ]
}
