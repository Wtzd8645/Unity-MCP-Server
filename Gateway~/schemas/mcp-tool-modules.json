{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity MCP Tool Modules",
  "version": "0.1.0",
  "modules": [
    {
      "name": "project_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_project_ping",
        "unity_project_get_info",
        "unity_project_get_build_settings",
        "unity_project_list_build_scenes",
        "unity_project_get_player_settings",
        "unity_project_get_project_settings"
      ]
    },
    {
      "name": "project_execute",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_project_run_tests",
        "unity_project_switch_build_target",
        "unity_project_build_player"
      ]
    },
    {
      "name": "project_write",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_project_set_build_scenes"
      ]
    },
    {
      "name": "editor_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_editor_get_console_logs",
        "unity_editor_get_selection"
      ]
    },
    {
      "name": "editor_execute",
      "risk": "low-medium",
      "enabledByDefault": false,
      "tools": [
        "unity_editor_set_selection",
        "unity_editor_frame_selection"
      ]
    },
    {
      "name": "editor_write",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_editor_clear_console"
      ]
    },
    {
      "name": "runtime_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_runtime_get_playmode_status"
      ]
    },
    {
      "name": "runtime_execute",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_runtime_start_playmode",
        "unity_runtime_stop_playmode"
      ]
    },
    {
      "name": "scene_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_scene_list",
        "unity_scene_list_loaded",
        "unity_scene_get_active"
      ]
    },
    {
      "name": "scene_execute",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_scene_open",
        "unity_scene_set_active",
        "unity_scene_close"
      ]
    },
    {
      "name": "scene_write",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_scene_create",
        "unity_scene_save",
        "unity_scene_save_all"
      ]
    },
    {
      "name": "gameobject_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_gameobject_find",
        "unity_gameobject_get",
        "unity_gameobject_list_components",
        "unity_gameobject_get_component_fields",
        "unity_gameobject_get_component_fields_batch"
      ]
    },
    {
      "name": "gameobject_write",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_gameobject_create",
        "unity_gameobject_delete",
        "unity_gameobject_duplicate",
        "unity_gameobject_reparent",
        "unity_gameobject_rename",
        "unity_gameobject_set_active",
        "unity_gameobject_set_transform",
        "unity_gameobject_set_tag",
        "unity_gameobject_set_layer",
        "unity_gameobject_set_static",
        "unity_gameobject_add_component",
        "unity_gameobject_remove_component",
        "unity_gameobject_set_component_fields"
      ]
    },
    {
      "name": "prefab_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_prefab_asset_get",
        "unity_prefab_instance_get",
        "unity_prefab_instance_get_overrides",
        "unity_prefab_asset_find_gameobjects",
        "unity_prefab_asset_get_gameobject",
        "unity_prefab_asset_get_component_fields"
      ]
    },
    {
      "name": "prefab_write",
      "risk": "medium-high",
      "enabledByDefault": false,
      "tools": [
        "unity_prefab_asset_create",
        "unity_prefab_instance_create",
        "unity_prefab_instance_apply_overrides",
        "unity_prefab_instance_revert_overrides",
        "unity_prefab_instance_unpack",
        "unity_prefab_asset_create_variant"
      ]
    },
    {
      "name": "asset_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_asset_find",
        "unity_asset_get",
        "unity_asset_get_references"
      ]
    },
    {
      "name": "asset_write",
      "risk": "high",
      "enabledByDefault": false,
      "tools": [
        "unity_asset_move",
        "unity_asset_rename",
        "unity_asset_delete_to_trash",
        "unity_asset_reimport",
        "unity_asset_import",
        "unity_asset_set_labels",
        "unity_asset_copy",
        "unity_asset_create_folder",
        "unity_asset_create_text",
        "unity_asset_create_material",
        "unity_asset_create_scriptable_object"
      ]
    }
  ]
}
