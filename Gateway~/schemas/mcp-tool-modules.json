{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity MCP Tool Modules",
  "version": "0.1.0",
  "modules": [
    {
      "name": "core",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_ping",
        "unity_project_info",
        "unity_playmode_status",
        "unity_playmode_start",
        "unity_playmode_stop"
      ]
    },
    {
      "name": "diagnostics",
      "risk": "low-medium",
      "enabledByDefault": true,
      "tools": [
        "unity_get_console_logs",
        "unity_clear_console",
        "unity_run_tests"
      ]
    },
    {
      "name": "scene_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_list_scenes",
        "unity_open_scene",
        "unity_go_find",
        "unity_component_get_fields"
      ]
    },
    {
      "name": "scene_write",
      "risk": "medium",
      "enabledByDefault": false,
      "tools": [
        "unity_go_create",
        "unity_go_delete",
        "unity_go_duplicate",
        "unity_go_reparent",
        "unity_go_rename",
        "unity_go_set_active",
        "unity_component_add",
        "unity_component_remove",
        "unity_component_set_fields"
      ]
    },
    {
      "name": "prefab_write",
      "risk": "medium-high",
      "enabledByDefault": false,
      "tools": [
        "unity_prefab_create",
        "unity_prefab_instantiate",
        "unity_prefab_apply_overrides",
        "unity_prefab_revert_overrides",
        "unity_prefab_unpack",
        "unity_prefab_create_variant"
      ]
    },
    {
      "name": "asset_read",
      "risk": "low",
      "enabledByDefault": true,
      "tools": [
        "unity_asset_search",
        "unity_asset_get",
        "unity_asset_refs"
      ]
    },
    {
      "name": "asset_write",
      "risk": "high",
      "enabledByDefault": false,
      "tools": [
        "unity_asset_move",
        "unity_asset_rename",
        "unity_asset_delete_to_trash",
        "unity_asset_reimport",
        "unity_asset_set_labels"
      ]
    }
  ]
}

