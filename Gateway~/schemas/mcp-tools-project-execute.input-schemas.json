{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity MCP Project Execute Tool Input Schemas",
  "version": "0.1.0",
  "$defs": {
    "scenePath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.unity$",
      "description": "Scene path under Assets/"
    },
    "guid": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{32}$",
      "description": "Unity GUID"
    },
    "assetPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Asset path under Assets/"
    },
    "folderPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Folder path under Assets/"
    },
    "prefabPath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.prefab$",
      "description": "Prefab path under Assets/"
    },
    "assetRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "guid": {
              "$ref": "#/$defs/guid"
            }
          },
          "required": [
            "guid"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "$ref": "#/$defs/assetPath"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        }
      ]
    },
    "gameObjectRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "globalObjectId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "globalObjectId"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "scenePath": {
              "$ref": "#/$defs/scenePath"
            },
            "hierarchyPath": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "scenePath",
            "hierarchyPath"
          ],
          "additionalProperties": false
        }
      ]
    },
    "vec3": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false
    },
    "transformInput": {
      "type": "object",
      "properties": {
        "position": {
          "$ref": "#/$defs/vec3"
        },
        "rotationEuler": {
          "$ref": "#/$defs/vec3"
        },
        "scale": {
          "$ref": "#/$defs/vec3"
        },
        "local": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "mutateFlags": {
      "type": "object",
      "allOf": [
        {
          "if": {
            "required": [
              "dryRun"
            ]
          },
          "then": {
            "required": [
              "apply"
            ]
          }
        },
        {
          "if": {
            "required": [
              "apply"
            ]
          },
          "then": {
            "required": [
              "dryRun"
            ]
          }
        },
        {
          "if": {
            "required": [
              "dryRun",
              "apply"
            ]
          },
          "then": {
            "oneOf": [
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": true
                  },
                  "apply": {
                    "const": false
                  }
                }
              },
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": false
                  },
                  "apply": {
                    "const": true
                  }
                }
              }
            ]
          }
        }
      ]
    }
  },
  "tools": [
    {
      "name": "unity_project_run_tests",
      "description": "Run Unity Test Framework tests (defaults to EditMode).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "EditMode",
              "PlayMode"
            ],
            "default": "EditMode"
          },
          "filter": {
            "type": "object",
            "properties": {
              "assemblyNames": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "testNames": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "categoryNames": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 5000,
            "maximum": 3600000,
            "default": 600000
          },
          "includePassed": {
            "type": "boolean",
            "default": false
          },
          "includeXmlReportPath": {
            "type": "boolean",
            "default": true
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "unity_project_switch_build_target",
      "description": "Switch the active Unity build target synchronously.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "buildTarget": {
            "type": "string",
            "minLength": 1,
            "description": "Unity BuildTarget enum name."
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 5000,
            "maximum": 3600000,
            "default": 600000
          }
        },
        "required": [
          "buildTarget"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "unity_project_build_player",
      "description": "Build the player for the current active build target using enabled Build Settings scenes.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "outputPath": {
            "type": "string",
            "pattern": "^Builds\\/.*$|^Builds/.*$",
            "minLength": 8,
            "description": "Project-relative output path under Builds/."
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 10000,
            "maximum": 7200000,
            "default": 1800000
          }
        },
        "required": [
          "outputPath"
        ],
        "additionalProperties": false
      }
    }
  ]
}
