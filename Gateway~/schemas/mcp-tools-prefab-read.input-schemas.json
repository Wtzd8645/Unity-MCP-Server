{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity MCP Prefab Read Tool Input Schemas",
  "version": "0.1.0",
  "$defs": {
    "scenePath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.unity$",
      "description": "Scene path under Assets/"
    },
    "guid": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{32}$",
      "description": "Unity GUID"
    },
    "assetPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Asset path under Assets/"
    },
    "folderPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Folder path under Assets/"
    },
    "prefabPath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.prefab$",
      "description": "Prefab path under Assets/"
    },
    "assetRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "guid": {
              "$ref": "#/$defs/guid"
            }
          },
          "required": [
            "guid"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "$ref": "#/$defs/assetPath"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        }
      ]
    },
    "gameObjectRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "globalObjectId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "globalObjectId"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "scenePath": {
              "$ref": "#/$defs/scenePath"
            },
            "hierarchyPath": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "scenePath",
            "hierarchyPath"
          ],
          "additionalProperties": false
        }
      ]
    },
    "vec3": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false
    },
    "transformInput": {
      "type": "object",
      "properties": {
        "position": {
          "$ref": "#/$defs/vec3"
        },
        "rotationEuler": {
          "$ref": "#/$defs/vec3"
        },
        "scale": {
          "$ref": "#/$defs/vec3"
        },
        "local": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "mutateFlags": {
      "type": "object",
      "allOf": [
        {
          "if": {
            "required": [
              "dryRun"
            ]
          },
          "then": {
            "required": [
              "apply"
            ]
          }
        },
        {
          "if": {
            "required": [
              "apply"
            ]
          },
          "then": {
            "required": [
              "dryRun"
            ]
          }
        },
        {
          "if": {
            "required": [
              "dryRun",
              "apply"
            ]
          },
          "then": {
            "oneOf": [
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": true
                  },
                  "apply": {
                    "const": false
                  }
                }
              },
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": false
                  },
                  "apply": {
                    "const": true
                  }
                }
              }
            ]
          }
        }
      ]
    }
  },
  "tools": [
    {
      "name": "unity_prefab_asset_get",
      "description": "Inspect a prefab asset summary.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prefab": {
            "$ref": "#/$defs/assetRef"
          }
        },
        "required": [
          "prefab"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "unity_prefab_instance_get",
      "description": "Inspect a prefab instance summary.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "instance": {
            "$ref": "#/$defs/gameObjectRef"
          }
        },
        "required": [
          "instance"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "unity_prefab_instance_get_overrides",
      "description": "Inspect detailed overrides for one prefab instance root.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "instance": {
            "$ref": "#/$defs/gameObjectRef"
          }
        },
        "required": [
          "instance"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "unity_prefab_asset_find_gameobjects",
      "description": "Search GameObjects inside a prefab asset by hierarchy, type, or metadata filters.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prefab": {
            "$ref": "#/$defs/assetRef"
          },
          "namePattern": {
            "type": "string",
            "minLength": 1
          },
          "tag": {
            "type": "string",
            "minLength": 1
          },
          "layer": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "hasComponents": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "hierarchyPathPrefix": {
            "type": "string",
            "minLength": 1
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000,
            "default": 200
          },
          "offset": {
            "type": "integer",
            "minimum": 0,
            "default": 0
          }
        },
        "required": [
          "prefab"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "unity_prefab_asset_get_gameobject",
      "description": "Get a prefab asset GameObject snapshot including hierarchy, local transform, and component summary.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prefab": {
            "$ref": "#/$defs/assetRef"
          },
          "hierarchyPath": {
            "type": "string",
            "minLength": 1
          },
          "includeChildren": {
            "type": "boolean",
            "default": true
          },
          "childLimit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 500,
            "default": 100
          }
        },
        "required": [
          "prefab",
          "hierarchyPath"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "unity_prefab_asset_get_component_fields",
      "description": "Read serialized fields from a component inside a prefab asset.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prefab": {
            "$ref": "#/$defs/assetRef"
          },
          "hierarchyPath": {
            "type": "string",
            "minLength": 1
          },
          "componentIndex": {
            "type": "integer",
            "minimum": 0
          },
          "includePrivateSerialized": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "prefab",
          "hierarchyPath",
          "componentIndex"
        ],
        "additionalProperties": false
      }
    }
  ]
}
