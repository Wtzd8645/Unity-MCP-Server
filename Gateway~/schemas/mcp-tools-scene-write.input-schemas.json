{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity MCP Scene Write Tool Input Schemas",
  "version": "0.1.0",
  "$defs": {
    "scenePath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.unity$",
      "description": "Scene path under Assets/"
    },
    "guid": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{32}$",
      "description": "Unity GUID"
    },
    "assetPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Asset path under Assets/"
    },
    "folderPath": {
      "type": "string",
      "pattern": "^Assets\\/.*$",
      "description": "Folder path under Assets/"
    },
    "prefabPath": {
      "type": "string",
      "pattern": "^Assets\\/.*\\.prefab$",
      "description": "Prefab path under Assets/"
    },
    "assetRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "guid": {
              "$ref": "#/$defs/guid"
            }
          },
          "required": [
            "guid"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "$ref": "#/$defs/assetPath"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        }
      ]
    },
    "gameObjectRef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "globalObjectId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "globalObjectId"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "scenePath": {
              "$ref": "#/$defs/scenePath"
            },
            "hierarchyPath": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "scenePath",
            "hierarchyPath"
          ],
          "additionalProperties": false
        }
      ]
    },
    "vec3": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false
    },
    "transformInput": {
      "type": "object",
      "properties": {
        "position": {
          "$ref": "#/$defs/vec3"
        },
        "rotationEuler": {
          "$ref": "#/$defs/vec3"
        },
        "scale": {
          "$ref": "#/$defs/vec3"
        },
        "local": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "mutateFlags": {
      "type": "object",
      "allOf": [
        {
          "if": {
            "required": [
              "dryRun"
            ]
          },
          "then": {
            "required": [
              "apply"
            ]
          }
        },
        {
          "if": {
            "required": [
              "apply"
            ]
          },
          "then": {
            "required": [
              "dryRun"
            ]
          }
        },
        {
          "if": {
            "required": [
              "dryRun",
              "apply"
            ]
          },
          "then": {
            "oneOf": [
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": true
                  },
                  "apply": {
                    "const": false
                  }
                }
              },
              {
                "required": [
                  "dryRun",
                  "apply"
                ],
                "properties": {
                  "dryRun": {
                    "const": false
                  },
                  "apply": {
                    "const": true
                  }
                }
              }
            ]
          }
        }
      ]
    }
  },
  "tools": [
    {
      "name": "unity_scene_create",
      "description": "Create and save a new scene asset.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "outputPath": {
            "$ref": "#/$defs/scenePath"
          },
          "setup": {
            "type": "string",
            "enum": [
              "EmptyScene",
              "DefaultGameObjects"
            ],
            "default": "EmptyScene"
          },
          "openMode": {
            "type": "string",
            "enum": [
              "Single",
              "Additive"
            ],
            "default": "Additive"
          },
          "setActive": {
            "type": "boolean",
            "default": true
          },
          "overwrite": {
            "type": "boolean",
            "default": false
          },
          "dirtyEditorContextPolicy": {
            "type": "string",
            "enum": [
              "ErrorIfDirty",
              "SaveSaved",
              "DiscardDirty"
            ],
            "default": "ErrorIfDirty"
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "outputPath"
        ],
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity_scene_save",
      "description": "Save a loaded scene, optionally to a new output path.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "scenePath": {
            "$ref": "#/$defs/scenePath"
          },
          "outputPath": {
            "$ref": "#/$defs/scenePath"
          },
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    },
    {
      "name": "unity_scene_save_all",
      "description": "Save all loaded scenes that have paths.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "dryRun": {
            "type": "boolean",
            "default": true
          },
          "apply": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "$ref": "#/$defs/mutateFlags"
          }
        ]
      }
    }
  ]
}
